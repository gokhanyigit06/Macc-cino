# Copy to .env for local development.

# SQLite database location.
# - Local dev: file:./dev.db  (resolved relative to the prisma/ directory)
# - Production: point at a PERSISTENT VOLUME so data survives redeploys,
#   e.g. file:/app/data/prod.db  (mount a volume at /app/data on your host).
DATABASE_URL="file:./dev.db"

# Optional: JWT signing secret for admin auth (falls back to a default if unset).
# JWT_SECRET="change-me"

# Optional: port (defaults to 3000).
# PORT=3000
