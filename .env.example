# Copy to .env for local development.

# PostgreSQL connection string.
# - Production: injected by the host (Coolify) automatically.
# - Local dev: point at a local PostgreSQL instance, e.g.
#   postgresql://postgres:postgres@localhost:5432/macccino?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/macccino?schema=public"

# Optional: JWT signing secret for admin auth (falls back to a default if unset).
# JWT_SECRET="change-me"

# Optional: port (defaults to 3000).
# PORT=3000
