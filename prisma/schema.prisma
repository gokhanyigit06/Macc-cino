generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection string is provided by the host (Coolify) via DATABASE_URL.
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Settings {
  key   String @id
  value String // JSON string for flexibility
}

model BlogPost {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  imageUrl  String?
  // Optional translations (fall back to the base TR fields when empty)
  title_de   String?
  title_en   String?
  content_de String?
  content_en String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  category    String   // gastronomy, office, hotel, etc.
  imageUrl    String?
  features    String?  // JSON string or comma separated
  sectors     String?  // CSV of sector slugs: "office,hotel,fitness,bakery,gastronomy,gas-station,chains"
  isVisible   Boolean  @default(true)
  // Optional translations (fall back to the base TR fields when empty)
  name_de        String?
  name_en        String?
  description_de String?
  description_en String?
  features_de    String?
  features_en    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id        Int      @id @default(autoincrement())
  type      String   // "image" | "video"
  mediaUrl  String
  title     String?
  subtitle  String?
  // Optional translations (fall back to the base TR fields when empty)
  title_de    String?
  title_en    String?
  subtitle_de String?
  subtitle_en String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PageVisit {
  id        Int      @id @default(autoincrement())
  pageUrl   String
  visitorIp String?  // Hashed for privacy
  userAgent String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  sector    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
